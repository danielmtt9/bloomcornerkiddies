{
  "name": "bloomcornerkiddies-scripts",
  "version": "1.0.1",
  "description": "Developer utility scripts for Bloom Corner Kiddies setup",
  "type": "module",
  "scripts": {
    "hash":       "node scripts/generate-hash.mjs",
    "migrate":    "node scripts/migrate.mjs",
    "test-config":"php scripts/test-config-example.php",
    "test-deploy":"bash scripts/test-deploy-workflow.sh",
    "test-php-bootstrap":"php scripts/test-php-bootstrap.php",
