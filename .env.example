# ==============================================================
# Bloom Corner Kiddies — Environment Variables
# ==============================================================
# LOCATION: /home/u746391188/.env  (one level ABOVE public_html/)
# NEVER commit this file — it is in .gitignore
# Copy this template to your server and fill in missing values
# ==============================================================

# ----- Database -----------------------------------------------
# Hostinger shared hosting — connect via localhost on server
DB_HOST=localhost
DB_NAME=u746391188_bloomcorner
DB_USER=u746391188_bloomcorner
DB_PASS=PLACEHOLDER_db_password_from_hpanel
# Optional: only needed for remote connections (not on server)
DB_PORT=3306

# ----- Admin Panel --------------------------------------------
# Generate with: npm run hash   (or: php -r "echo password_hash('pass', PASSWORD_BCRYPT);")
ADMIN_PASSWORD_HASH=PLACEHOLDER_run_npm_run_hash_and_paste_here

# ----- Telegram Bot -------------------------------------------
# Get token from @BotFather on Telegram after creating your bot
TELEGRAM_BOT_TOKEN=PLACEHOLDER_telegram_bot_token
# Get your chat_id by messaging @userinfobot on Telegram
TELEGRAM_SELLER_CHAT_ID=PLACEHOLDER_your_telegram_chat_id

# ----- Store Contact (confirmed values) -----------------------
WA_NUMBER=2349049308656
TELEGRAM_LINK=https://t.me/+2349049308656

# ----- App Environment ----------------------------------------
APP_ENV=production
