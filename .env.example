# ==============================================================
# Bloom Corner Kiddies — Environment Variables Template
# ==============================================================
# USAGE:
#   1. Copy this file to .env (one level ABOVE public_html/ on server)
#   2. Fill in all values below
#   3. NEVER commit .env to git — it is in .gitignore
# ==============================================================

# ----- Database -----------------------------------------------
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# ----- Admin Panel --------------------------------------------
# Generate with: php -r "echo password_hash('your_password', PASSWORD_BCRYPT);"
ADMIN_PASSWORD_HASH=

# ----- Telegram Bot -------------------------------------------
# Get from @BotFather after creating your bot
TELEGRAM_BOT_TOKEN=

# Seller's Telegram chat_id (for receiving order notifications)
# Find yours by messaging @userinfobot on Telegram
TELEGRAM_SELLER_CHAT_ID=

# ----- Store Contact ------------------------------------------
WA_NUMBER=2349049308656
TELEGRAM_LINK=https://t.me/+2349049308656

# ----- App Environment ----------------------------------------
APP_ENV=production
# Set to 'development' locally to enable PHP error display
